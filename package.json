{
  "name": "@velobaseai/billing",
  "version": "1.1.1",
  "description": "Velobase Billing SDK for JavaScript/TypeScript",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run test/unit",
    "test:unit": "vitest run test/unit",
    "test:watch": "vitest test/unit",
    "test:integration": "vitest run test/integration.test.ts",
    "test:coverage": "vitest run test/unit --coverage",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "velobase",
    "billing",
    "credits",
    "api",
    "sdk"
  ],
  "author": "Velobase",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/velobase/velobase-billing-js.git"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.6"
  }
}
